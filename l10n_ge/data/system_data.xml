<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="base.lang_ka_GE" model="res.lang">
            <field name="active">true</field>
            <field name="week_start">1</field>
            <field name="date_format">%d.%m.%Y</field>
            <field name="time_format">%H:%M:%S</field>
            <field name="decimal_point">.</field>
            <field name="thousands_sep">,</field>
        </record>
        <record id="base.main_company" model="res.company">
            <field name="currency_provider">nbg</field>
        </record>
        <function model="decimal.precision" name="write">
            <value model="decimal.precision" eval="obj().env.ref('product.decimal_price').id"/>
            <value eval="{'digits': 4}"/>
        </function>
    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="l10n_ge_rule_pension_emp" model="hr.salary.rule">
            <field name="name">Pension (Employee 2%)</field>
            <field name="code">PENS_EMP</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = employee.x_is_pension_member</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = -(categories.GROSS * 0.02)</field>
        </record>

        <record id="l10n_ge_rule_income_tax" model="hr.salary.rule">
            <field name="name">Income Tax (20%)</field>
            <field name="code">ITAX</field>
            <field name="sequence">30</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="condition_select">none</field> <field name="amount_select">code</field>
            <field name="amount_python_compute">
# Fetch pension deduction if it exists, otherwise 0
pension = abs(result_rules.get('PENS_EMP', {}).get('total', 0))
result = -((categories.GROSS - pension) * 0.20)
            </field>
        </record>
        <record id="l10n_ge_rule_insurance_benefit" model="hr.salary.rule">
            <field name="name">Health Insurance Benefit (Taxable)</field>
            <field name="code">INS_BENEFIT</field>
            <field name="sequence">5</field>
            <field name="category_id" ref="hr_payroll.ALW"/> <field name="amount_select">fix</field>
            <field name="amount_fix">50.00</field>
        </record>

        <record id="l10n_ge_rule_insurance_offset" model="hr.salary.rule">
            <field name="name">Health Insurance Offset</field>
            <field name="code">INS_OFF</field>
            <field name="sequence">100</field> <field name="category_id" ref="hr_payroll.DED"/>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = -result_rules['INS_BENEFIT']['total']</field>
        </record>
        <record id="l10n_ge_rule_pension_co" model="hr.salary.rule">
            <field name="name">Pension (Company 2%)</field>
            <field name="code">PENS_CO</field>
            <field name="sequence">40</field>
            <field name="category_id" ref="hr_payroll.COMP"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = employee.x_is_pension_member</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = categories.GROSS * 0.02</field>
        </record>

        <record id="structure_ge_employee" model="hr.payroll.structure">
            <field name="name">Georgia: Standard Employee</field>
            <field name="type_id" ref="hr_payroll.structure_type_employee"/>
            <field name="rule_ids" eval="[
                (4, ref('hr_payroll.hr_rule_basic')),
                (4, ref('l10n_ge_rule_pension_emp')),
                (4, ref('l10n_ge_rule_income_tax')),
                (4, ref('l10n_ge_rule_pension_co')),
                (4, ref('hr_payroll.hr_rule_net'))
            ]"/>
        </record>
    </data>
</odoo>